{
  "manifest_version": 3,
  "name": "Simple Navigation",
  "short_name": "SimpleNav",
  "version": "1.0.0",
  "description": "静态导航新标签页，兼容 Chrome 和 Edge",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "action": {
    "default_title": "Simple Navigation"
  },
  "icons": {
    "16": "icon-dark-32x32.png",
    "32": "icon-dark-32x32.png",
    "48": "icon-light.png",
    "128": "apple-icon.png"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
